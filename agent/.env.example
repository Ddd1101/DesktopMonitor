# 服务端地址
SERVER_URL=http://localhost:3000

# Agent 注册预置 Token（与服务端 AGENT_REGISTER_TOKEN 一致）
AGENT_REGISTER_TOKEN=change-me-please

# 截图采集间隔（秒）
SCREENSHOT_INTERVAL=30

# 活动窗口采样间隔（秒）
WINDOW_SAMPLE_INTERVAL=1

# 活动事件聚合周期（秒）
EVENT_AGGREGATE_INTERVAL=30

# 上传器轮询间隔（秒）
UPLOAD_INTERVAL=60

# 截图大小阈值（KB），超过则自动降低清晰度重新压缩
SCREENSHOT_MAX_SIZE_KB=200

# 截图最大宽度（像素），高分屏（如4K）超出时等比缩小
SCREENSHOT_MAX_WIDTH=1920

# 日志级别
LOG_LEVEL=INFO
