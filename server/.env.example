# 服务端端口
PORT=3000

# JWT 密钥（生产环境务必修改）
JWT_SECRET=default-jwt-secret-change-me

# Agent 注册预置 Token（需与 Agent 端 .env 中的 AGENT_REGISTER_TOKEN 一致）
AGENT_REGISTER_TOKEN=change-me-please

# 默认管理员密码（首次启动时创建 admin 账号）
ADMIN_DEFAULT_PASSWORD=admin123

# 数据目录
DATA_DIR=./data
SCREENSHOTS_DIR=./data/screenshots
DB_PATH=./data/app.db

# 心跳超时（秒），超过此时间未收到心跳则视为离线
HEARTBEAT_TIMEOUT_SECONDS=90
